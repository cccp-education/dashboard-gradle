<!DOCTYPE html>
<html lang="fr" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title th:text="${page.title}">Dashboard Workspace CCCP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" th:href="@{styles.css}" href="styles.css">
</head>
<body>
<nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
        <span class="navbar-brand mb-0 h1" th:text="${page.title}">Dashboard Workspace CCCP</span>
        <span class="navbar-text text-light">
            <span th:text="${page.stats.boroughCount}">0</span> boroughs —
            <span th:text="${page.stats.epicCount}">0</span> epics
        </span>
    </div>
</nav>

<div class="container-fluid mt-4">
    <div class="row g-4">
        <!-- Stats cards -->
        <div class="col-12">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="card stats-card stats-done">
                        <div class="card-body text-center">
                            <h5 class="card-title">Terminés</h5>
                            <p class="display-6" th:text="${page.stats.doneCount}">0</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card stats-in-progress">
                        <div class="card-body text-center">
                            <h5 class="card-title">En cours</h5>
                            <p class="display-6" th:text="${page.stats.inProgressCount}">0</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card stats-planned">
                        <div class="card-body text-center">
                            <h5 class="card-title">Planifiés</h5>
                            <p class="display-6" th:text="${page.stats.plannedCount}">0</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stats-card stats-blocked">
                        <div class="card-body text-center">
                            <h5 class="card-title">Bloqués</h5>
                            <p class="display-6" th:text="${page.stats.blockedCount}">0</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- EPIC Matrix -->
        <div class="col-lg-8">
            <div class="card dashboard-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">EPIC Matrix</h2>
                    <span class="badge bg-secondary" th:text="${page.epics.size} + ' epics'">0 epics</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                            <tr>
                                <th>EPIC</th>
                                <th>Sujet</th>
                                <th>Priorité</th>
                                <th>Statut</th>
                            </tr>
                            </thead>
                            <tbody>
                            <th:block th:each="group : ${page.boroughGroups}" th:if="${not #lists.isEmpty(group.epics)}">
                                <tr class="borough-header">
                                    <td colspan="4">
                                        <strong th:text="${group.name} + ' (' + ${group.dagLevel} + ')'">Dashboard (N3)</strong>
                                        <small class="text-muted ms-2" th:text="${group.project}">dashboard-gradle</small>
                                    </td>
                                </tr>
                                <tr th:each="epic : ${group.epics}" th:class="'status-row ' + ${statusHelper.statusCssClass(epic.status)}">
                                    <td th:text="${epic.id}">DSH-0</td>
                                    <td th:text="${epic.title}">Bootstrap</td>
                                    <td th:text="${epic.priority}">P0</td>
                                    <td>
                                        <span class="status-badge" th:class="'status-badge ' + ${statusHelper.statusCssClass(epic.status)}"
                                              th:text="${epic.status}">TERMINE</span>
                                    </td>
                                </tr>
                            </th:block>
                            <tr th:if="${#lists.isEmpty(page.epics)}">
                                <td colspan="4" class="text-center text-muted py-4">Aucun EPIC détecté</td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Activity Stream -->
        <div class="col-lg-4">
            <div class="card dashboard-card">
                <div class="card-header">
                    <h2 class="h5 mb-0">Activity Stream</h2>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item activity-item" th:each="session : ${page.sessions}">
                            <div class="d-flex w-100 justify-content-between">
                                <strong class="mb-1" th:text="'S' + ${session.number}">S000</strong>
                                <small class="text-muted" th:text="${session.date}">2026-06-22</small>
                            </div>
                            <p class="mb-1" th:text="${session.subject}">Sujet de la session</p>
                            <small class="text-muted" th:text="${session.borough} + (${session.files.isEmpty()} ? '' : ' — ' + ${session.files})">Borough</small>
                        </li>
                        <li class="list-group-item text-center text-muted py-4" th:if="${#lists.isEmpty(page.sessions)}">
                            Aucune session récente
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="col-12">
            <div class="card dashboard-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Timeline</h2>
                    <span class="badge bg-secondary" th:text="${page.timeline.milestones.size} + ' milestones'">0 milestones</span>
                </div>
                <div class="card-body p-0">
                    <div class="timeline-wrapper">
                        <ul class="timeline list-unstyled mb-0 py-4 px-3">
                            <li class="timeline-item" th:each="milestone : ${page.timeline.milestones}">
                                <div class="timeline-marker" th:class="'timeline-marker status-' + ${milestone.status}"></div>
                                <div class="timeline-content">
                                    <div class="d-flex w-100 justify-content-between">
                                        <strong class="mb-1" th:text="${milestone.label}">Bootstrap</strong>
                                        <small class="text-muted" th:text="${milestone.date}">2026-06-18</small>
                                    </div>
                                    <small class="text-muted" th:text="${milestone.borough} + ' (' + ${milestone.dagLevel} + ') — ' + ${milestone.id}">Dashboard (N3) — DSH-0</small>
                                </div>
                            </li>
                            <li class="timeline-item text-center text-muted py-4" th:if="${#lists.isEmpty(page.timeline.milestones)}">
                                Aucun jalon disponible
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- DAG Graph -->
        <div class="col-12">
            <div class="card dashboard-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">DAG Graph</h2>
                    <span class="badge bg-secondary" th:text="${page.dagGraph.nodes.size} + ' boroughs / ' + ${page.dagGraph.edges.size} + ' edges'">0 / 0</span>
                </div>
                <div class="card-body">
                    <div id="dag-graph" class="dag-graph-canvas"></div>
                    <p class="text-muted mt-2 mb-0 small" th:if="${#lists.isEmpty(page.dagGraph.nodes)}">
                        Aucun graphe DAG disponible.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="bg-dark text-white mt-5 py-3">
    <div class="container text-center">
        <p class="mb-0">&copy; 2026 CCCP Education — Dashboard workspace</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
<script type="application/json" id="dag-graph-data" th:utext="${page.dagGraphJson}">{"nodes":[],"edges":[]}</script>
<script>
    (function() {
        var dataElement = document.getElementById('dag-graph-data');
        var parsed = dataElement ? JSON.parse(dataElement.textContent) : { nodes: [], edges: [] };
        var container = document.getElementById('dag-graph');
        if (container && parsed.nodes.length > 0) {
            var nodes = new vis.DataSet(parsed.nodes.map(function(n) {
                return { id: n.id, label: n.label, level: n.level, group: n.group };
            }));
            var edges = new vis.DataSet(parsed.edges.map(function(e) {
                return { from: e.from, to: e.to, arrows: 'to' };
            }));
            var options = {
                layout: {
                    hierarchical: {
                        direction: 'LR',
                        sortMethod: 'directed',
                        levelSeparation: 180,
                        nodeSpacing: 160
                    }
                },
                physics: { hierarchicalRepulsion: { nodeDistance: 140 } },
                groups: {
                    'N0': { color: { background: '#6f42c1', border: '#5936a2' }, font: { color: '#fff' } },
                    'N1': { color: { background: '#0d6efd', border: '#0a58ca' }, font: { color: '#fff' } },
                    'N2': { color: { background: '#198754', border: '#146c43' }, font: { color: '#fff' } },
                    'N3': { color: { background: '#fd7e14', border: '#ca6510' }, font: { color: '#fff' } },
                    'N4': { color: { background: '#dc3545', border: '#b02a37' }, font: { color: '#fff' } }
                },
                nodes: { shape: 'box', margin: 10, font: { size: 14 } }
            };
            new vis.Network(container, { nodes: nodes, edges: edges }, options);
        }
    })();
</script>
</body>
</html>
